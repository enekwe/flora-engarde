# Server
NODE_ENV=development
PORT=4010
SERVICE_NAME=flora-engarde

# Database (isolated per microservice per Flora Development Rules)
MONGODB_URI=mongodb://localhost:27017/flora-engarde

# En Garde OAuth 2.0 + PKCE (engarde-api authorization server)
ENGARDE_API_URL=https://api.engardehq.com
ENGARDE_OAUTH_CLIENT_ID=
ENGARDE_OAUTH_CLIENT_SECRET=
ENGARDE_OAUTH_REDIRECT_URI=https://flora.passbook.vc/api/v1/integrations/engarde/callback
# offline_access is required for engarde-api to issue a refresh token.
# Other scopes match engarde-api's public API v1 enforcement (audiences/analytics are read-only there today).
ENGARDE_OAUTH_SCOPES=campaigns:read campaigns:write analytics:read audiences:read assets:read assets:write offline_access

# Flora session JWT (issued by the passbook-flora monolith) — verifies GP/Founder/Admin callers
JWT_SECRET=
INTERNAL_SERVICE_TOKEN=

# Webhook ingestion (US-3.1.5): shared HMAC-SHA256 secret for X-Engarde-Signature
# Generate with: openssl rand -hex 32 — must match the value configured on En Garde's side
ENGARDE_WEBHOOK_SECRET=

# Analytics cache TTL in seconds (US-3.1.4, default 60)
ANALYTICS_CACHE_TTL_SECONDS=60

# AES-256-GCM key for the En Garde token vault — 64 hex chars (32 bytes).
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY=

# Where to bounce the GP's browser back into Flora after the OAuth round-trip
FLORA_APP_URL=https://flora.passbook.vc

# CORS
ALLOWED_ORIGINS=https://flora.passbook.vc
