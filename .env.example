# Server
NODE_ENV=development
PORT=4010
SERVICE_NAME=flora-engarde

# Database (isolated per microservice per Flora Development Rules)
MONGODB_URI=mongodb://localhost:27017/flora-engarde

# En Garde OAuth 2.0 + PKCE (engarde-api authorization server)
ENGARDE_API_URL=https://api.engardehq.com
ENGARDE_OAUTH_CLIENT_ID=
ENGARDE_OAUTH_CLIENT_SECRET=
ENGARDE_OAUTH_REDIRECT_URI=https://flora.passbook.vc/api/v1/engarde/oauth/callback
# Scopes enforced by engarde-api's public API v1 (assets/audiences/analytics are read-only there today)
ENGARDE_OAUTH_SCOPES=campaigns:read campaigns:write analytics:read audiences:read assets:read

# Internal service auth (Flora monolith <-> this microservice)
JWT_SECRET=
INTERNAL_SERVICE_TOKEN=

# CORS
ALLOWED_ORIGINS=https://flora.passbook.vc
